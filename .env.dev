# Variables de entorno para desarrollo local (docker-compose)
# Copiar este archivo a .env.dev y ajustar los valores si es necesario.
# NUNCA commitear .env.dev — está en .gitignore.

# ── Base de datos PostgreSQL ─────────────────────────────────────────────────
# DSN estándar. Para docker-compose local, los valores por defecto son triviales.
BETIX_DB_URL=postgresql://betix:betix@localhost:5432/betix

# ── Core Flask ───────────────────────────────────────────────────────────────
CORE_PORT=5000

# ── API Node.js ──────────────────────────────────────────────────────────────
NODE_ENV=dev
BETIX_PORT=3000
CORE_URL=http://localhost:5000
REDIS_URL=redis://localhost:6379
CACHE_TTL=60
