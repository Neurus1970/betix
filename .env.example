# Variables de entorno de Betix API
# Tienen prioridad sobre betix.properties cuando están definidas

# Puerto del servidor
BETIX_PORT=3000

# Nivel de logging (error, warn, info, http, verbose, debug, silly)
BETIX_LOG_LEVEL=info

# Destino de los logs: console | file | both
BETIX_LOG_OUTPUT=console

# Ruta del archivo de log (usado cuando BETIX_LOG_OUTPUT es "file" o "both")
BETIX_LOG_FILE=logs/betix.log
