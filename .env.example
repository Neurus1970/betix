# Plantilla de variables de entorno — copiar al archivo del perfil correspondiente
# El perfil activo se selecciona con NODE_ENV (dev | uat | pro)
#
# Archivos de perfil incluidos en el repo:
#   .env.dev  → desarrollo local  (LOG_LEVEL=debug, OUTPUT=console)
#   .env.uat  → testing/QA        (LOG_LEVEL=info,  OUTPUT=both)
#   .env.pro  → producción        (LOG_LEVEL=warn,  OUTPUT=file)

# Puerto del servidor
BETIX_PORT=3000

# Nivel de logging (error | warn | info | http | verbose | debug | silly)
BETIX_LOG_LEVEL=info

# Destino de los logs (console | file | both)
BETIX_LOG_OUTPUT=console

# Ruta del archivo de log (usado cuando OUTPUT es "file" o "both")
BETIX_LOG_FILE=logs/betix.log
